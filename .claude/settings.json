{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "jq -e '.tool_input.command | test(\"git commit\")' >/dev/null 2>&1 && git push --quiet 2>&1; true",
            "statusMessage": "Auto-pushing to origin..."
          }
        ]
      }
    ]
  }
}
