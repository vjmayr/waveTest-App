# Copy to /etc/wavetest-app/litestream.env on the server and `chmod 600`.
# The credentials are issued in the Hetzner Console under Project → Object
# Storage → Manage Tokens.

LITESTREAM_BUCKET=wavetest-app-backups
LITESTREAM_ENDPOINT=https://fsn1.your-objectstorage.com
LITESTREAM_REGION=fsn1
LITESTREAM_ACCESS_KEY_ID=...
LITESTREAM_SECRET_ACCESS_KEY=...
